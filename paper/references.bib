% =====================================================================
% Prospective reflection / planning - closest competing approach
% =====================================================================

@misc{wang2026preflect,
  author    = {Wang, Hanyu and Cao, Yuanpu and Lin, Lu and Chen, Jinghui},
  title     = {{PreFlect}: From Retrospective to Prospective Reflection in
               Large Language Model Agents},
  year      = {2026},
  url       = {https://arxiv.org/abs/2602.07187},
  note      = {Closest existing work to ASP. PreFlect shifts the
               self-reflection paradigm from post-hoc correction to
               pre-execution criticism of agent plans, distilling planning
               errors from historical trajectories and adding dynamic
               re-planning. ASP differs by enforcing prompt-isolated
               validators (Iron Law 2), process-level subprocess isolation
               (Iron Law 10), and the file-based parent/child contract.},
}

